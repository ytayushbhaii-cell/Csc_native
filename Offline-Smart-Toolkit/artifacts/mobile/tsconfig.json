{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "jsx": "react-native",
    "strict": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "expo-router": ["./shims/expo-router"],
      "expo-status-bar": ["./shims/expo-status-bar"],
      "expo-splash-screen": ["./shims/expo-splash-screen"],
      "expo-clipboard": ["./shims/expo-clipboard"],
      "expo-linear-gradient": ["./shims/expo-linear-gradient"],
      "@expo/vector-icons": ["./shims/expo-vector-icons"],
      "@expo-google-fonts/inter": ["./shims/expo-google-fonts-inter"],
      "expo-image-manipulator": ["./shims/expo-image-manipulator"],
      "expo-image": ["./shims/expo-image"],
      "expo-document-picker": ["./shims/expo-document-picker"],
      "expo-file-system": ["./shims/expo-file-system"],
      "expo-file-system/legacy": ["./shims/expo-file-system-legacy"],
      "expo-image-picker": ["./shims/expo-image-picker"],
      "expo-sharing": ["./shims/expo-sharing"],
      "expo-media-library": ["./shims/expo-media-library"],
      "expo-camera": ["./shims/expo-camera"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "shims/*.ts",
    "shims/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "android",
    "ios",
    "dist",
    "server",
    "scripts"
  ]
}

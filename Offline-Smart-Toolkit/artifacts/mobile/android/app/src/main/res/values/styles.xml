<resources>
  <!-- Base application theme (used by MainActivity) -->
  <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
    <item name="android:statusBarColor">@android:color/transparent</item>
    <item name="android:windowLightStatusBar">true</item>
    <item name="colorPrimary">@color/colorPrimary</item>
    <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
  </style>

  <!-- Bootstrap theme shown while React Native JS loads (transparent status bar, white bg) -->
  <style name="BootstrapTheme" parent="AppTheme">
    <item name="android:windowBackground">@color/splashscreen_background</item>
  </style>
</resources>
